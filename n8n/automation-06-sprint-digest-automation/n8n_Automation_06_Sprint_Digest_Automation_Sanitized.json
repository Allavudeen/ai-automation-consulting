      "parameters": {
        "jsCode": "const raw = $input.first().json.text;\n\nlet html = raw\n  .replace(/\\*\\*(.*?)\\*\\*/g, \"<b>$1</b>\")\n  .replace(/\\n/g, \"<br>\");\n\nreturn [{ json: { htmlBody: html } }];"
      },
