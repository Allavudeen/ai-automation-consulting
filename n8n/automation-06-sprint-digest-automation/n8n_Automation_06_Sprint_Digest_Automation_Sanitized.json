    {
      "parameters": {
        "jsCode": "// Parse the MCP tool result (comes back as a JSON string inside content[0].text)\nconst data = $input.first().json.content[0].text;\nconst issues = data.issues;\n\nconst today = new Date();\ntoday.setHours(0, 0, 0, 0);\n\nconst processed = issues.map(issue => {\n  const fields = issue.fields;\n  const dueDate = fields.duedate ? new Date(fields.duedate) : null;\n  const status = fields.status?.name || \"Unknown\";\n  const summary = fields.summary || \"\";\n\n  const isBlocked = summary.toLowerCase().includes(\"blocked\");\n  const isOverdue = dueDate && dueDate < today && status !== \"Done\";\n  const isDone = status === \"Done\";\n\n  let riskLevel = \"on-track\";\n  if (isBlocked) riskLevel = \"blocked\";\n  else if (isOverdue) riskLevel = \"at-risk\";\n\n  return {\n    key: issue.key,\n    summary: summary,\n    status: status,\n    dueDate: fields.duedate || null,\n    assignee: fields.assignee?.displayName || \"Unassigned\",\n    issueType: fields.issuetype?.name || \"Task\",\n    riskLevel: riskLevel,\n    isDone: isDone,\n  };\n});\n\n// Group into buckets for the digest\nconst summary = {\n  total: processed.length,\n  done: processed.filter(i => i.isDone).length,\n  inProgress: processed.filter(i => i.status === \"In Progress\").length,\n  toDo: processed.filter(i => i.status === \"To Do\").length,\n  inReview: processed.filter(i => i.status === \"In Review\").length,\n  blocked: processed.filter(i => i.riskLevel === \"blocked\"),\n  atRisk: processed.filter(i => i.riskLevel === \"at-risk\"),\n  allIssues: processed,\n};\n\nreturn [{ json: summary }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
