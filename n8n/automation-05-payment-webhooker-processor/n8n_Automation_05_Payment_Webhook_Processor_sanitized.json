        "jsCode": "const aiText = $input.first().json.text;\n\nlet parsed;\ntry {\n  // Safety net in case Groq ever wraps in ```json fences\n  const cleaned = aiText.replace(/```json/g, '').replace(/```/g, '').trim();\n  parsed = JSON.parse(cleaned);\n} catch (error) {\n  throw new Error(`Failed to parse AI output as JSON: ${aiText}`);\n}\n\nreturn [{\n  json: {\n    ...($('Validate Payload').first().json),\n    cleaned_name: parsed.cleaned_name,\n    category: parsed.category\n  }\n}];"
      },
