        "messages": {
          "messageValues": [
            {
              "message": "=You are a data-cleaning assistant for a payment processing log. You will receive a raw customer name and a raw transaction description. Perform two tasks:       1. Clean the customer name: fix capitalization to proper Title Case (e.g. \"rajesh kumar s\" -> \"Rajesh Kumar S\"). Do not add or remove words.       2. Classify the transaction description into EXACTLY ONE of these categories: Payment, Refund, Subscription, Chargeback, Other. Base the category only on the meaning of the description text.       Respond ONLY with valid JSON, no markdown formatting, no code fences, no preamble. Use this exact structure:      {\"cleaned_name\": \"string\", \"category\": \"string\"}"
            }
          ]
        },
        "batching": {}
      },
